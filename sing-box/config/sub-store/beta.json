      //},
      {
        "tag": "Ali-QUIC",
        "type": "quic",
        "server_port": 853,
        "server": "223.5.5.5"
      },
      {
        "tag": "hosts",
        "type": "hosts",
        "predefined": {
          "filter.yylx.win": "152.32.240.17"
        }
      },
      {
        "tag": "Pollution-DNS",
        "type": "https",
        "domain_resolver": "hosts",
        "server_port": 443,
        "server": "filter.yylx.win",
        "path": "/apt-get"
      }
      //{
      //  "tag": "Cloudflare-DNS",
      //  "type": "https",
      //  "detour": "🇭🇰HK",
      //  "server_port": 443,
      //  "server": "1.1.1.1",
      //  "path": "/dns-query"
      //}
    ],
    "rules": [
      {
        "action": "predefined",
        "rule_set": [
          "reject_non_ip",
          "reject_domainset",
          "reject_non_ip_drop",
          "reject_non_ip_no_drop"
        ],
        "rcode": "NOERROR"
      },
      {
        "action": "route",
        "clash_mode": "direct",
        "server": "Ali-QUIC"
      },
      {
        "action": "route",
        "clash_mode": "global",
        "server": "Fake-IP"
      },
      {
        "action": "route",
        "rule_set": [
          "private-geosite",
          "connectivity-check-geosite",
          "ForceDirect",
          "Bilibili",
          "domestic_non_ip",
          "direct_non_ip",
          "DirectSupplements"
        ],
        "server": "Local",
        "disable_cache": false
      },
      { "action": "predefined", "query_type": "PTR", "rcode": "NXDOMAIN" },
      {
        "action": "predefined",
        "query_type": ["SVCB", "HTTPS"],
        "rcode": "NOERROR"
      },
      {
        "action": "route",
        "query_type": ["A", "AAAA"],
        "server": "Fake-IP",
        "rewrite_ttl": 300
      }
    ],
    "final": "Pollution-DNS",
    //"strategy": "prefer_ipv6",
    //"client_subnet": "1.1.1.1/32",
    //"disable_cache": false,
    //"disable_expire": false,
    "optimistic": {
      "enabled": true,
      "timeout": "3d"
    },
    "reverse_mapping": true
  },
  "ntp": {
    "enabled": false,
    "server": "ntp.aliyun.com",
    "server_port": 123,
    "interval": "30m",
    "detour": "🇨🇳CN"
